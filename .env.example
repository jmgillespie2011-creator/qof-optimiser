# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLISHABLE-KEY
# Server-only. NEVER expose to the browser. Used by ingestion scripts / admin.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Published QOF year to display (set after loading real data). Default: 2025/26 (sample)
NEXT_PUBLIC_QOF_YEAR=2025/26

# AI features (Feature 1: QI plans). Server-only — never expose to the browser.
ANTHROPIC_API_KEY=YOUR-ANTHROPIC-API-KEY
# Optional overrides (defaults shown). Model identity is a config value.
# ANTHROPIC_MODEL=claude-sonnet-5
# AI_RATE_PER_SESSION_HOUR=20
# AI_RATE_GLOBAL_DAY=500
